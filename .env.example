# Copy this file to .env if you prefer env vars over ~/.shadow/config.json.
# NEVER commit .env — it is in .gitignore.
#
# These three env vars override the matching fields in ~/.shadow/config.json.

SHADOW_GATEWAY_URL=https://your-internal-gateway-url/path
SHADOW_API_TOKEN=your-api-token-here
SHADOW_CMDB_ID=APM0000000
